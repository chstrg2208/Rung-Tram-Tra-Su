# This .gitignore file should be placed at the root of your Unity project.
#
# Root-level ignore patterns
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Cc]oBuild/
/[Ll]ogs/
/[Mm]emory[Cc]aptures/
/[Uu]ser[Ss]ettings/

# Large assets exceeding GitHub limits
/Assets/Proxy Games/Stylized Nature Kit Lite/Misc/HDRI.hdr

# Agent and IDE local files
/docs/
/Assets/Screenshots/
*.slnx


# Asset-specific ignore patterns
/[Aa]ssets/AssetStoreTools*

# Autogenerated project files
/Assets/Plugins/Editor/JetBrains*
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.db
sysinfo.txt

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]sset[Ss]ettings/[Cc]onfig/[Cc]onfig.json
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa/*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
